
/* Tutorial 7: Form formatting */
form {
  background-color: #fff8ef;
  padding: 20px;
  border: 2px solid #4b1e1e;
  border-radius: 10px;
}

fieldset {
  margin-bottom: 20px;
  padding: 15px;
  border: 1px solid #8b4513;
}

legend {
  font-weight: bold;
  color: #4b1e1e;
}

label {
  display: block;
  margin-top: 10px;
}

input, select, textarea {
  display: block;
  margin-top: 5px;
  margin-bottom: 10px;
  padding: 8px;
  max-width: 100%;
}

/* Tutorial 7: Focus pseudo class with valid and invalid boxes */
input:focus:valid,
textarea:focus:valid {
  background-color: #e6ffe6;
}

input:focus:invalid,
textarea:focus:invalid {
  background-color: #ffe6e6;
}
